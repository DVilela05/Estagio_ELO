@startuml sequencia_consultar_ferias
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName "Segoe UI"
skinparam sequenceMessageAlign center
skinparam maxMessageSize 220
skinparam sequenceParticipantFontSize 11
skinparam sequenceMessageFontSize 11

title Diagrama de Sequência — Consultar Férias

actor "Colaborador" as user
participant "WhatsApp /\nTeams" as api <<API>>
participant "WebhookController" as ctrl <<Api Layer>>
participant "MessageProcessing\nService" as mps <<Application>>
participant "CommandRouter" as router <<Core>>
participant "ListagemFerias\nCommandHandler" as ferCmd <<Core>>
participant "BotLocalizer" as localizer <<Core>>
participant "WebServiceUtils" as ws <<Infrastructure>>
participant "ELO WCF\n(metalf1)" as elo <<Sistema Legado>>
participant "IMessagingService" as msgSvc <<Infrastructure>>

' ─── Etapa 1: Trigger Inicial ─────────────────────────────

user -> api : Envia "férias"
api -> ctrl : HTTP POST (Webhook)
ctrl -> mps : ProcessMessageAsync(msg)

note over mps
  Férias não requer confirmação
  → execução direta (bypass)
end note

mps -> router : RouteAsync(msg)
router -> ferCmd : ExecuteAsync(msg)

ferCmd -> ferCmd : Detetar idioma pelo trigger
ferCmd -> ferCmd : Criar PendingFeriasState\n(estado = AwaitingYear)

ferCmd -> localizer : Get("Ferias_AskYear", lang)
localizer --> ferCmd : "Para qual ano queres consultar?"

ferCmd --> mps : resposta
mps -> msgSvc : SendTextMessage(resposta)
msgSvc -> api : HTTP POST
api -> user : "Para qual ano pretendes\nconsultar as férias?"

' ─── Etapa 2: Utilizador indica o ano ─────────────────────

... Utilizador responde ...

user -> api : Envia "2026"
api -> ctrl : HTTP POST (Webhook)
ctrl -> mps : ProcessMessageAsync(msg)
mps -> router : RouteAsync(msg)
router -> ferCmd : ExecuteAsync(msg)

ferCmd -> ferCmd : Estado = AwaitingYear
ferCmd -> ferCmd : TryExtractYear("2026")

note over ferCmd
  Regex: \b(20\d{2})\b
  Extrai ano de 4 dígitos
  no intervalo 20XX
end note

ferCmd -> ferCmd : Ano extraído: 2026
ferCmd -> ferCmd : Estado → AwaitingConfirmation

ferCmd -> localizer : Get("Ferias_ConfirmYear",\nlang, "2026")
localizer --> ferCmd : "Confirmas férias para\no ano 2026? (sim/não)"

ferCmd --> mps : resposta
mps -> msgSvc : SendTextMessage(resposta)
msgSvc -> api : HTTP POST
api -> user : "Confirmas? (sim/não)"

' ─── Etapa 3: Confirmação ─────────────────────────────────

... Utilizador responde ...

user -> api : Envia "sim"
api -> ctrl : HTTP POST (Webhook)
ctrl -> mps : ProcessMessageAsync(msg)
mps -> router : RouteAsync(msg)
router -> ferCmd : ExecuteAsync(msg)

ferCmd -> ferCmd : Estado = AwaitingConfirmation
ferCmd -> ferCmd : IsYes("sim") → true

ferCmd -> ferCmd : ProcessFeriasAsync()

ferCmd -> ferCmd : Construir parâmetro:\nTOKEN|apiType|telefone|\nferias|data|email|ano

ferCmd -> ferCmd : Codificar parâmetro

ferCmd -> ws : WCFRESTServiceCall(\n"POST", "metalf1", paramCodificado)

ws -> elo : HTTP POST (REST)\nBody: parâmetro codificado

note over elo #FADBD8
  1. Descodificar parâmetro
  2. Validar utilizador
  3. Consultar férias
     do ano na BD
  4. Devolver resposta codificada
end note

elo --> ws : Resposta codificada

ws --> ferCmd : rawResponse

ferCmd -> ferCmd : Descodificar resposta
ferCmd -> ferCmd : Formatar resposta

ferCmd --> mps : resposta formatada
mps -> msgSvc : SendTextMessage(resposta)
msgSvc -> api : HTTP POST
api -> user : "🏖️ Férias para 2026..."

@enduml
