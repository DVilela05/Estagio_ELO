@startuml security_pipeline
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName Segoe UI

title Pipeline de Segurança (ordem simplificada)

rectangle "Global Middleware" #E8F1FF {
  component "ExceptionHandlingMiddleware" as ex
  component "SecurityHeadersMiddleware" as sec
  component "CorrelationIdMiddleware" as corr
  component "Rate Limiter" as rl
}

rectangle "Endpoint WhatsApp" #EEF9F0 {
  component "ValidateWhatsAppSignatureFilter\n(HMAC + FixedTimeEquals)" as waSig
  component "WhatsAppConcurrencyGuardFilter\n(dedup + lock remetente)" as waGuard
  component "WebhookController" as waCtrl
}

rectangle "Endpoint Teams" #FFF7E8 {
  component "ValidateTeamsJwtFilter\n(OpenID + JWT validation)" as teamsJwt
  component "WebhookController" as teamsCtrl
}

ex --> sec
sec --> corr
corr --> rl

rl --> waSig
waSig --> waGuard
waGuard --> waCtrl

rl --> teamsJwt
teamsJwt --> teamsCtrl

@enduml
