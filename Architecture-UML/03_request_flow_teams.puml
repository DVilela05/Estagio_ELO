@startuml request_flow_teams
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontName Segoe UI

actor "Utilizador Teams" as u
participant "Microsoft Teams" as teamsClient
participant "ValidateTeamsJwtFilter" as jwt
participant "WebhookController\nPOST /api/webhook/teams" as ctrl
participant "MessageProcessingService" as proc
participant "CommandRouter" as router
participant "PresencaCommandHandler" as pres
participant "BusinessApiClient" as biz
participant "TeamsService" as teamsSvc
participant "Bot Framework\nConnector" as connector

u -> teamsClient : envia mensagem ao bot
teamsClient -> jwt : activity + bearer token
jwt -> ctrl : valida JWT (issuer/audience/chaves)
jwt --> teamsClient : 401 (se inválido)

alt activity tipo message
  ctrl -> proc : SafeProcessMessageAsync(msg)
  proc -> teamsSvc : MarkAsReadAsync() (no-op)
  proc -> router : RouteAsync / confirmação
  alt presença confirmada + PIN
    router -> pres : ExecuteAsync()
    pres -> biz : RegisterAttendanceAsync()
    biz --> pres : resultado
  end
  proc -> teamsSvc : SendTextMessageAsync(reply)
  teamsSvc -> connector : POST /v3/conversations/.../activities
  connector --> teamsSvc : 200 / erro
end

ctrl --> teamsClient : HTTP 200 OK
teamsClient --> u : mostra reply

@enduml
