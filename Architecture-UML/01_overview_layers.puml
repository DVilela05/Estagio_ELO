@startuml overview_layers
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName Segoe UI

left to right direction

actor "Utilizador\n(WhatsApp/Teams)" as user

rectangle "API Layer" #E8F1FF {
  component "WebhookController" as webhook
  component "HealthController" as health
  component "Security Filters\n(HMAC / JWT / Concurrency)" as filters
}

rectangle "Application Layer" #EEF9F0 {
  component "MessageProcessingService" as processing
  component "WebhookConcurrencyGuard" as guard
}

rectangle "Core Layer" #FFF7E8 {
  component "CommandRouter" as router
  component "ICommandHandler\n(Help / Presença / Admin)" as commands
  component "Interfaces\n(IMessagingService / IBusinessApiClient)" as contracts
}

rectangle "Infrastructure Layer" #F5EEFF {
  component "MessagingServiceFactory" as factory
  component "WhatsAppService" as wa
  component "TeamsService" as teams
  component "BusinessApiClient" as biz
}

cloud "Meta WhatsApp API" as meta
cloud "Microsoft Bot Framework" as botfw
cloud "ERP / Business API" as erp

user --> webhook
webhook --> filters
webhook --> processing
processing --> router
router --> commands
processing --> factory
factory --> wa
factory --> teams
commands --> biz
wa --> meta
teams --> botfw
biz --> erp

@enduml
